// =================================================================
// BRAND-ON — Firebase Storage beveiligingsregels
// -----------------------------------------------------------------
// Plak deze regels in:
//   Firebase Console > Storage > Rules
//
// Wat dit doet:
//   - concept-uploads/: iedereen mag schrijven (publiek aanvraagformulier),
//     beperkt op bestandsgrootte (10 MB) en type (afbeelding of PDF).
//   - Al het overige in Storage is geblokkeerd.
// =================================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Concept website aanvragen — openbaar uploadpad
    match /concept-uploads/{filename} {
      // Lezen: iedereen (zodat de download-URL werkt)
      allow read: if true;

      // Schrijven: iedereen, maar alleen geldige bestanden
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Al het overige is geblokkeerd
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
